PORT=3000
NODE_ENV=production

# ⚠️ 部署前務必修改!
JWT_SECRET=your-super-secret-random-key-min-32-characters

# CORS 設定 (你的前端域名)
# 開發時用 *，生產環境指定域名
CORS_ORIGIN=https://your-domain.com

# 資料庫路徑 (生產環境建議絕對路徑)
# Windows: C:\GameLauncher\data\database.sqlite
# Linux: /var/lib/gamelauncher/database.sqlite
DB_PATH=./database.sqlite

# 日誌設定
LOG_LEVEL=info

# 可選: 使用外部資料庫 (未來擴充)
# DB_TYPE=sqlite
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=gamelauncher
# DB_USER=gamelauncher
# DB_PASS=your-db-password
